{
  "name": "amc-transfer",
  "version": "1.0.0",
  "description": "Copy photos and videos from Android phone to local computer via ADB",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "setup": "node scripts/setup.js",
    "setup:current": "node scripts/setup.js --current",
    "dist": "npm run build && pkg ."
  },
  "dependencies": {
    "exifr": "^7.1.3",
    "express": "^4.18.2",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.10",
    "@yao-pkg/pkg": "^5.11.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2",
    "unzipper": "^0.12.3"
  },
  "pkg": {
    "scripts": ["dist/**/*.js"],
    "assets": ["public/**/*", "bin/**/*"],
    "targets": [
      "node20-win-x64",
      "node20-macos-x64",
      "node20-macos-arm64",
      "node20-linux-x64"
    ],
    "outputPath": "release"
  }
}
